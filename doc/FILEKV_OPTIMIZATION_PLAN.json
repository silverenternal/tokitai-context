  "optimization_plan": {
    "p0_critical": [
      {
        "id": "P0-01",
        "title": "Replace SHA256 with xxHash",
        "problem": "SHA256 is a cryptographic hash (~10µs), overkill for KV indexing",
        "current_code": "let mut hasher = Sha256::new(); hasher.update(value);",
        "solution": {
          "dependency": "xxhash-rust = \"0.8\"",
          "code_change": "use xxhash_rust::xxh3::xxh3_64; let hash = xxh3_64(value);",
          "expected_improvement": "~10µs → ~1µs per hash operation"
        },
        "estimated_impact": "Baseline ~45µs → ~35µs (10µs saved per write)"
      },
      {
        "id": "P0-02",
        "title": "Fix Bloom Filter Short-Circuit",
        "problem": "Bloom Filter negative result does not short-circuit the read path",
        "current_code": "if !bloom.might_contain(key) { /* should return here */ } // but continues to check MemTable, Cache, Segment...",
        "solution": {
          "code_change": "if !bloom.might_contain(key) { self.stats.write().bloom_filtered += 1; return Ok(None); }",
          "location": "file_kv.rs:get() method, early return path"
        },
        "estimated_impact": "Negative lookup ~66µs → ~1µs (66x improvement)"
      }
    ],
    
    "p1_high": [
      {
        "id": "P1-01",
        "title": "BlockCache with DashMap + Arc",
        "problem": "Cache uses Mutex + clone, adding ~10µs overhead",
        "current_code": "let mut cache = self.data.lock(); cache.get(&hash).cloned();",
        "solution": {
          "data_structure": "use dashmap::DashMap<u64, Arc<[u8]>>",
          "code_change": "self.data.get(&hash).map(|e| Arc::clone(&e.value()))",
          "benefit": "Lock-free + zero-copy"
        },
        "estimated_impact": "Hot read ~47µs → ~5µs (10x improvement)"
      },
      {
        "id": "P1-02",
        "title": "Promote put_batch() API",
        "problem": "Users use single put() which has 170x higher per-item cost",
        "solution": {
          "api_design": "pub fn put_batch(&self, entries: &[(&str, &[u8])]) -> Result<usize>",
          "documentation": "Add examples showing batch usage",
          "facade_integration": "Context::store_batch() wrapper in facade.rs"
        },
        "estimated_impact": "User workloads see 10-100x throughput improvement"
      }
    ],
    
    "p2_medium": [
      {
        "id": "P2-01",
        "title": "Split file_kv.rs into Modules",
        "problem": "2050 lines in single file reduces maintainability",
        "proposed_structure": {
          "file_kv/mod.rs": "Main FileKV struct and public API",
          "file_kv/memtable.rs": "MemTable implementation",
          "file_kv/segment.rs": "SegmentFile implementation",
          "file_kv/wal.rs": "WAL integration",
          "file_kv/cache.rs": "BlockCache implementation",
          "file_kv/bloom.rs": "Bloom Filter integration",
          "file_kv/compaction.rs": "CompactionManager integration"
        },
        "estimated_effort": "4-6 hours",
        "status": "✅ Completed",
        "completed_date": "2026-04-02",
        "actual_structure": {
          "file_kv/mod.rs": "889 lines - Main FileKV struct and public API",
          "file_kv/types.rs": "347 lines - ValuePointer, Config, Stats types",
          "file_kv/segment.rs": "375 lines - SegmentFile implementation",
          "file_kv/memtable.rs": "217 lines - MemTable implementation",
          "file_kv/flush.rs": "120 lines - Background flush thread and trigger",
          "file_kv/wal.rs": "82 lines - WAL integration helpers",
          "file_kv/bloom.rs": "5 lines - Bloom filter re-exports",
          "file_kv/compaction.rs": "6 lines - Compaction wrapper"
        },
        "actual_result": "2041 lines across 8 files (avg 255 lines/file), 29% reduction in mod.rs"
      },
      {
        "id": "P2-02",
        "title": "Use Bytes Type for Values",
        "problem": "Vec<u8> clone is expensive",
        "solution": {
          "dependency": "bytes = \"1.5\"",
          "api_change": "pub fn put(&self, key: &str, value: &Bytes) -> Result<()>",
          "benefit": "Bytes uses Arc internally, clone is zero-copy"
        },
        "estimated_impact": "Value clone ~5µs → ~0µs"
      },
      {
        "id": "P2-03",
        "title": "Pre-allocate Segment Files",
        "problem": "File system fragmentation from growing files",
        "solution": {
          "code_change": "file.set_len(preallocated_size) when creating segment",
          "config_option": "segment_preallocate_size: Option<u64> in FileKVConfig"
        },
        "estimated_impact": "Sequential write throughput +10-20%"
      }
    ],
    
    "p3_future": [
      {
        "id": "P3-01",
        "title": "Background Flush Thread Tuning",
        "description": "Current implementation exists but needs tuning",
        "tuning_parameters": [
          "flush_interval_ms: configurable (default 100ms)",
          "flush_threshold_bytes: adaptive based on write rate",
          "graceful shutdown on drop"
        ]
      },
      {
        "id": "P3-02",
        "title": "io_uring Integration (Linux only)",
        "description": "Async I/O for reduced syscall overhead",
        "dependencies": ["tokio-uring", "iou"],
        "estimated_impact": "I/O latency -30-50%",
        "complexity": "High, requires significant refactoring"
      },
      {
        "id": "P3-03",
        "title": "Zero-Copy Read with mmap",
        "description": "Return &[u8] from mmap instead of Vec<u8>",
        "benefit": "Eliminates kernel-to-user space copy",
        "estimated_impact": "Large value read +2-3x"
      }
    ]
  },

