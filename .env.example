# Tokitai-Context AI Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# Alibaba Cloud Coding Plan (阿里云百炼 AI 编码套餐)
# =============================================================================
# Get your API key from: https://bailian.console.aliyun.com
# IMPORTANT: Must use Coding Plan exclusive API Key and Base URL
# ALIYUN_CODING_PLAN_API_KEY="your-coding-plan-api-key"
# DASHSCOPE_API_KEY="your-dashscope-api-key"  # Alternative variable name

# =============================================================================
# OpenAI
# =============================================================================
# Get your API key from: https://platform.openai.com
# OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxx"

# =============================================================================
# Anthropic
# =============================================================================
# Get your API key from: https://console.anthropic.com
# ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxx"

# =============================================================================
# Ollama (Self-hosted)
# =============================================================================
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3.1"

# =============================================================================
# Generic AI Configuration (for simple setups)
# =============================================================================
# AI_API_KEY="your-api-key-here"
# AI_API_URL="https://api.provider.com/v1/chat/completions"
# AI_MODEL="model-name"
